---
import Base from '../layouts/Base.astro';
---

<Base
  title="PDX Home Revival — Portland's Premier Deck & Patio Cover Builder"
  description="Custom-crafted decks and patio covers for Portland metro homeowners. Premium materials, architectural integration, Pacific Northwest craftsmanship."
>

  <!-- ═══════════════════════════════════════════════════
       HERO — Full-bleed cinematic, warm linen + forest
       ═══════════════════════════════════════════════════ -->
  <section class="pdx-hero relative min-h-[96vh] flex flex-col justify-end overflow-hidden">

    <!-- Layered gradient background: linen base → forest atmosphere -->
    <div class="pdx-hero-bg absolute inset-0" aria-hidden="true"></div>

    <!-- Noise grain overlay -->
    <div class="pdx-hero-grain absolute inset-0" aria-hidden="true"></div>

    <!-- Subtle cedar-tone vignette at top -->
    <div class="absolute inset-x-0 top-0 h-64 bg-gradient-to-b from-[oklch(0.22_0.05_162/0.55)] to-transparent" aria-hidden="true"></div>

    <!-- Hero content — anchored to bottom left for editorial feel -->
    <div class="relative z-10 max-w-7xl mx-auto w-full px-6 sm:px-10 lg:px-16 pt-28 md:pt-0 pb-20 md:pb-28">

      <!-- Eyebrow label -->
      <p class="pdx-eyebrow text-xs font-semibold tracking-[0.28em] uppercase text-accent-300 mb-7 animate-slide-up">
        Portland Metro · Est. 2001 · Oregon CCB Licensed
      </p>

      <!-- Main headline — dramatic Cormorant at scale -->
      <h1 class="font-display text-[3.5rem] sm:text-7xl lg:text-[6.5rem] xl:text-[8rem] leading-[0.93] tracking-tight text-surface-50 max-w-4xl animate-slide-up delay-100">
        Portland's&nbsp;Premier<br/>
        <em class="not-italic text-accent-400">Deck &amp;&nbsp;Patio</em><br/>
        Cover&nbsp;Builder
      </h1>

      <!-- Sub-headline -->
      <p class="mt-8 text-base md:text-lg font-body font-light text-surface-200/90 max-w-lg leading-relaxed animate-slide-up delay-200">
        We build outdoor spaces that look like they were always part of your home — architecturally integrated, weather-ready, and crafted for how Portland families actually live outdoors.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-slide-up delay-300">
        <a
          href="#consultation"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent-500 text-white font-body font-semibold text-base rounded-none hover:bg-accent-600 transition-colors duration-200"
        >
          Let's Design Your Space
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="#projects"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-surface-200/60 text-surface-100 font-body font-medium text-base rounded-none hover:border-accent-400 hover:text-accent-400 transition-colors duration-200"
        >
          View Our Work
        </a>
      </div>

      <!-- Micro-proof strip -->
      <div class="mt-14 flex flex-wrap gap-x-10 gap-y-3 animate-fade-in delay-400">
        <div class="flex items-center gap-2 text-surface-300">
          <!-- Star icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span class="text-sm font-body font-medium">4.9 / 5 on Google · 80+ Reviews</span>
        </div>
        <div class="flex items-center gap-2 text-surface-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
          <span class="text-sm font-body font-medium">Licensed & Insured · Oregon CCB</span>
        </div>
        <div class="flex items-center gap-2 text-surface-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="text-sm font-body font-medium">Serving Portland Metro Since 2001</span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 right-10 hidden lg:flex flex-col items-center gap-2 animate-fade-in delay-500" aria-hidden="true">
      <span class="text-xs tracking-[0.18em] uppercase text-surface-400 font-body" style="writing-mode: vertical-rl;">Scroll</span>
      <div class="w-px h-12 bg-gradient-to-b from-surface-400 to-transparent"></div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       MATERIALS TRUST BAR — Premium brands we build with
       ═══════════════════════════════════════════════════ -->
  <section class="py-10 bg-surface-900 border-b border-surface-800/60">
    <div class="max-w-6xl mx-auto px-6 sm:px-10 lg:px-16">
      <div class="flex flex-col sm:flex-row sm:items-center gap-6 sm:gap-10">
        <p class="text-xs tracking-[0.22em] uppercase text-surface-400 font-body whitespace-nowrap">We Build With</p>
        <div class="w-px h-6 bg-surface-700 hidden sm:block" aria-hidden="true"></div>
        <div class="flex flex-wrap items-center gap-x-10 gap-y-4">
          <span class="text-surface-300 font-display text-lg font-light tracking-wide">AZEK</span>
          <span class="text-surface-600" aria-hidden="true">·</span>
          <span class="text-surface-300 font-display text-lg font-light tracking-wide">TimberTech</span>
          <span class="text-surface-600" aria-hidden="true">·</span>
          <span class="text-surface-300 font-display text-lg font-light tracking-wide">Western Red Cedar</span>
          <span class="text-surface-600" aria-hidden="true">·</span>
          <span class="text-surface-300 font-display text-lg font-light tracking-wide">Trex</span>
          <span class="text-surface-600" aria-hidden="true">·</span>
          <span class="text-surface-300 font-display text-lg font-light tracking-wide">Fiberon</span>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       FEATURED PROJECTS — Architectural portfolio style
       ═══════════════════════════════════════════════════ -->
  <section id="projects" class="py-24 md:py-36 bg-surface-50">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16">

      <!-- Section header -->
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
        <div>
          <p class="text-xs tracking-[0.22em] uppercase text-accent-500 font-body mb-4">Featured Projects</p>
          <h2 class="font-display text-5xl md:text-6xl font-light text-surface-900 leading-tight max-w-xl">
            Spaces We've<br/><em>Brought to Life</em>
          </h2>
        </div>
        <p class="text-base font-body font-light text-surface-800 max-w-xs leading-relaxed">
          Each project is a collaboration — we listen to how you live before we ever break ground.
        </p>
      </div>

      <!-- Project grid — asymmetric, portfolio-style -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8">

        <!-- Project 1 — Large featured (spans 7 columns) -->
        <article class="lg:col-span-7 group relative overflow-hidden bg-brand-600" style="min-height: 520px;">
          <!-- Gradient stand-in for cinematic photography -->
          <div class="absolute inset-0 pdx-project-1" aria-hidden="true"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-surface-950/90 via-surface-950/30 to-transparent"></div>
          <div class="absolute inset-0 group-hover:bg-surface-950/20 transition-colors duration-500"></div>

          <!-- Project details — bottom left -->
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs tracking-[0.20em] uppercase text-accent-400 font-body">Cedar &amp; Composite · Lake Oswego</span>
            </div>
            <h3 class="font-display text-3xl md:text-4xl font-light text-white leading-tight mb-2">
              The Lake Oswego<br/>Cedar Retreat
            </h3>
            <p class="text-sm font-body font-light text-surface-300 mt-3 max-w-sm leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              Multi-level cedar deck with integrated pergola and ambient lighting. Designed to maximize views of the Willamette Valley while providing year-round outdoor comfort.
            </p>
            <div class="mt-5 flex items-center gap-2 text-accent-400 text-sm font-body font-medium opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">
              <span>View project details</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </article>

        <!-- Right column — two stacked projects -->
        <div class="lg:col-span-5 flex flex-col gap-6 md:gap-8">

          <!-- Project 2 -->
          <article class="group relative overflow-hidden bg-brand-500" style="min-height: 248px;">
            <div class="absolute inset-0 pdx-project-2" aria-hidden="true"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-surface-950/90 via-surface-950/20 to-transparent"></div>
            <div class="absolute inset-0 group-hover:bg-surface-950/15 transition-colors duration-500"></div>
            <div class="absolute bottom-0 left-0 right-0 p-7">
              <span class="text-xs tracking-[0.18em] uppercase text-accent-400 font-body">Patio Cover · West Linn</span>
              <h3 class="font-display text-2xl md:text-3xl font-light text-white mt-2 leading-tight">
                West Linn<br/>Pavilion Retreat
              </h3>
              <p class="text-xs font-body text-surface-300 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                Insulated aluminum cover with cedar beam accents — built for year-round outdoor dining.
              </p>
            </div>
          </article>

          <!-- Project 3 -->
          <article class="group relative overflow-hidden bg-brand-400" style="min-height: 248px;">
            <div class="absolute inset-0 pdx-project-3" aria-hidden="true"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-surface-950/90 via-surface-950/20 to-transparent"></div>
            <div class="absolute inset-0 group-hover:bg-surface-950/15 transition-colors duration-500"></div>
            <div class="absolute bottom-0 left-0 right-0 p-7">
              <span class="text-xs tracking-[0.18em] uppercase text-accent-400 font-body">TimberTech · SW Hills Portland</span>
              <h3 class="font-display text-2xl md:text-3xl font-light text-white mt-2 leading-tight">
                SW Hills<br/>Modern Terrace
              </h3>
              <p class="text-xs font-body text-surface-300 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                Multi-level TimberTech deck with frameless glass railing preserving the Forest Park treeline view.
              </p>
            </div>
          </article>

        </div>
      </div>

      <!-- Project 4 — Full-width landscape -->
      <article class="group relative overflow-hidden bg-brand-500 mt-6 md:mt-8" style="min-height: 400px;">
        <div class="absolute inset-0 pdx-project-4" aria-hidden="true"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-surface-950/80 via-surface-950/30 to-transparent"></div>
        <div class="absolute inset-0 group-hover:bg-surface-950/15 transition-colors duration-500"></div>
        <div class="absolute bottom-0 left-0 top-0 flex flex-col justify-end p-10 md:p-14 max-w-xl">
          <span class="text-xs tracking-[0.20em] uppercase text-accent-400 font-body">Cedar + Aluminum Cover · Beaverton</span>
          <h3 class="font-display text-3xl md:text-4xl font-light text-white mt-3 leading-tight">
            The Beaverton<br/>Entertainer's Oasis
          </h3>
          <p class="text-sm font-body font-light text-surface-300 mt-4 leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            960 sq ft wraparound deck with custom-built outdoor kitchen, louvered patio cover, and built-in bench seating for a family that loves to entertain.
          </p>
          <div class="mt-6 flex items-center gap-2 text-accent-400 text-sm font-body font-medium opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">
            <span>View project details</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </div>
      </article>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       PROCESS — How it works (3 elegant steps)
       ═══════════════════════════════════════════════════ -->
  <section class="py-24 md:py-32 bg-surface-100 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 sm:px-10 lg:px-16">

      <!-- Section header — left-aligned for editorial feel -->
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-20">
        <div>
          <p class="text-xs tracking-[0.28em] uppercase text-accent-500 font-body mb-4">The Process</p>
          <h2 class="font-display text-5xl md:text-6xl font-light text-surface-900 leading-tight">
            From First Call<br/><em>to First Morning Coffee</em><br/>on Your New Deck
          </h2>
        </div>
        <p class="font-body font-light text-sm text-surface-700 max-w-xs leading-relaxed lg:text-right lg:mb-2">
          Most of our clients have never worked with a contractor they fully trusted. Here's exactly how we change that.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 md:divide-x divide-surface-200">

        <!-- Step 1 -->
        <div class="md:pr-10 lg:pr-14 pb-10 md:pb-0">
          <!-- Large decorative numeral -->
          <p class="font-display text-[6rem] leading-none font-light text-surface-200 mb-4 select-none" aria-hidden="true">01</p>
          <div class="w-8 h-px bg-accent-500 mb-6"></div>
          <h3 class="font-display text-2xl font-semibold text-surface-900 mb-3">We Come to You</h3>
          <p class="font-body font-light text-sm text-surface-700 leading-relaxed">
            We visit your home at a time that works for you. We walk the space, ask how you use it, and listen — really listen — before suggesting anything. No laptop pitch, no upselling before we understand your life.
          </p>
          <p class="font-body text-xs font-semibold tracking-[0.12em] uppercase text-accent-500 mt-5">Free · No obligation</p>
        </div>

        <!-- Step 2 -->
        <div class="md:px-10 lg:px-14 border-t md:border-t-0 border-surface-200 pt-10 md:pt-0 pb-10 md:pb-0">
          <p class="font-display text-[6rem] leading-none font-light text-surface-200 mb-4 select-none" aria-hidden="true">02</p>
          <div class="w-8 h-px bg-brand-500 mb-6"></div>
          <h3 class="font-display text-2xl font-semibold text-surface-900 mb-3">Design &amp; Fixed-Price Proposal</h3>
          <p class="font-body font-light text-sm text-surface-700 leading-relaxed">
            You receive a scaled design drawing, physical material samples, and one transparent fixed price — covering every line item. No "allowance" placeholders, no change-order surprises when the cedar arrives.
          </p>
          <p class="font-body text-xs font-semibold tracking-[0.12em] uppercase text-brand-400 mt-5">Typically within 5 business days</p>
        </div>

        <!-- Step 3 -->
        <div class="md:pl-10 lg:pl-14 border-t md:border-t-0 border-surface-200 pt-10 md:pt-0">
          <p class="font-display text-[6rem] leading-none font-light text-surface-200 mb-4 select-none" aria-hidden="true">03</p>
          <div class="w-8 h-px bg-accent-500 mb-6"></div>
          <h3 class="font-display text-2xl font-semibold text-surface-900 mb-3">Built Clean, Delivered On Time</h3>
          <p class="font-body font-light text-sm text-surface-700 leading-relaxed">
            Our own crew — never a subcontractor — shows up when scheduled. Daily updates, a tidy jobsite, and a project manager you can actually reach. When we hand over your keys, it's inspection-ready and neighbor-stopping.
          </p>
          <p class="font-body text-xs font-semibold tracking-[0.12em] uppercase text-accent-500 mt-5">On-time delivery guaranteed</p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       WHY PDX HOME REVIVAL — Trust + differentiators
       ═══════════════════════════════════════════════════ -->
  <section class="py-24 md:py-36 bg-surface-50">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

        <!-- Left: Large editorial text -->
        <div>
          <p class="text-xs tracking-[0.22em] uppercase text-accent-500 font-body mb-5">Why PDX Home Revival</p>
          <h2 class="font-display text-5xl md:text-6xl font-light text-surface-900 leading-tight mb-8">
            We Build Spaces<br/>That <em>Impress</em><br/>For Decades
          </h2>
          <p class="font-body font-light text-base text-surface-800 leading-relaxed mb-8 max-w-md">
            Portland homeowners in Lake Oswego, West Linn, SW Hills, and Beaverton choose us because we treat every project like it's going on our own portfolio page — because it is.
          </p>

          <!-- Pull quote -->
          <blockquote class="border-l-2 border-accent-500 pl-6 py-2 my-8">
            <p class="font-display text-2xl font-light italic text-surface-800 leading-snug">
              "PDX Home Revival transformed our backyard into something we didn't think was possible. Neighbors ask about it constantly."
            </p>
            <cite class="font-body text-xs text-surface-600 not-italic tracking-wide mt-3 block">— Karen T. · Lake Oswego, OR</cite>
          </blockquote>

          <a href="#consultation" class="inline-flex items-center gap-2 text-sm font-body font-semibold text-brand-500 hover:text-accent-500 transition-colors duration-200 border-b border-brand-200 hover:border-accent-400 pb-1">
            Start your project consultation
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Right: Differentiator list -->
        <div class="space-y-8">

          <div class="flex gap-5 items-start">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-100 flex items-center justify-center mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h3 class="font-display text-xl font-medium text-surface-900 mb-1">Architecturally Integrated Design</h3>
              <p class="font-body font-light text-sm text-surface-700 leading-relaxed">We design decks and covers that look like they were planned when your house was built — not tacked on after the fact.</p>
            </div>
          </div>

          <div class="flex gap-5 items-start">
            <div class="flex-shrink-0 w-10 h-10 bg-accent-100 flex items-center justify-center mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
              </svg>
            </div>
            <div>
              <h3 class="font-display text-xl font-medium text-surface-900 mb-1">Premium Materials, Transparent Pricing</h3>
              <p class="font-body font-light text-sm text-surface-700 leading-relaxed">AZEK, TimberTech, and Western Red Cedar specified for your exact climate exposure and maintenance preference. Every material choice fully explained upfront.</p>
            </div>
          </div>

          <div class="flex gap-5 items-start">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-100 flex items-center justify-center mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-display text-xl font-medium text-surface-900 mb-1">On-Time Delivery, Guaranteed</h3>
              <p class="font-body font-light text-sm text-surface-700 leading-relaxed">We have a schedule we commit to and a project manager who keeps it. If we miss our promised date for reasons within our control, you don't pay for the overrun.</p>
            </div>
          </div>

          <div class="flex gap-5 items-start">
            <div class="flex-shrink-0 w-10 h-10 bg-accent-100 flex items-center justify-center mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
