---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "PDX Home Revival — Portland's Premier Deck & Patio Cover Builder",
  description = "Custom-crafted decks and patio covers for Portland metro homeowners. Premium materials, architecturally integrated, built for the Pacific Northwest lifestyle. Serving Lake Oswego, West Linn, SW Hills, Beaverton & all Portland metro."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "PDX Home Revival",
      "description": "Custom-crafted decks and patio covers for Portland metro homeowners. Premium materials, architecturally integrated, Pacific Northwest craftsmanship.",
      "url": "https://pdx-deck-specialists.onrender.com",
      "telephone": "+15035550100",
      "email": "hello@pdxhomerevival.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Portland",
        "addressRegion": "OR",
        "addressCountry": "US"
      },
      "areaServed": ["Lake Oswego", "West Linn", "Portland", "Beaverton", "Hillsboro", "Happy Valley"],
      "priceRange": "$$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "80"
      }
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
