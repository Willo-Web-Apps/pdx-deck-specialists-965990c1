---
---
<header class="pdx-header absolute top-0 left-0 right-0 z-50">
  <nav class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 h-20 flex items-center justify-between">

    <!-- Logo / Wordmark -->
    <a href="/" class="flex items-center gap-3 group">
      <!-- Cedar leaf mark -->
      <div class="w-8 h-8 flex-shrink-0">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
          <path d="M16 2C16 2 4 10 4 19C4 25.627 9.373 31 16 31C22.627 31 28 25.627 28 19C28 10 16 2 16 2Z" fill="oklch(0.61 0.12 60 / 0.90)"/>
          <path d="M16 6C16 6 8 13 8 20C8 24.418 11.582 28 16 28V6Z" fill="oklch(0.30 0.06 162 / 0.70)"/>
          <line x1="16" y1="31" x2="16" y2="18" stroke="oklch(0.97 0.008 78 / 0.50)" stroke-width="1"/>
        </svg>
      </div>
      <div>
        <span class="font-display text-xl font-medium text-white leading-none tracking-wide">PDX Home Revival</span>
        <span class="block text-xs font-body font-light text-white/50 tracking-[0.15em] uppercase mt-0.5">Custom Decks &amp; Patio Covers</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#projects" class="text-sm font-body font-medium text-white/70 hover:text-white transition-colors duration-150">Projects</a>
      <a href="#consultation" class="text-sm font-body font-medium text-white/70 hover:text-white transition-colors duration-150">Process</a>
      <a href="tel:5035550100" class="text-sm font-body font-medium text-white/70 hover:text-white transition-colors duration-150">(503) 555-0100</a>
      <a
        href="#consultation"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent-500 text-white font-body font-semibold text-sm hover:bg-accent-600 transition-colors duration-150"
      >
        Free Consultation
      </a>
    </div>

    <!-- Mobile CTA -->
    <div class="md:hidden">
      <a
        href="#consultation"
        class="inline-flex items-center gap-2 px-4 py-2.5 bg-accent-500 text-white font-body font-semibold text-xs hover:bg-accent-600 transition-colors duration-150"
      >
        Get a Consultation
      </a>
    </div>
  </nav>
</header>

<style>
  /* Header is absolute over hero; pages without hero need sticky fallback */
  .pdx-header {
    /* subtle bottom border only on scroll — handled by mix-blend for simplicity */
  }
</style>
