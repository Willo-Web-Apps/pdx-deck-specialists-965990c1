---
const year = new Date().getFullYear();
---
<footer class="bg-surface-900 pt-16 pb-10">
  <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16">

    <!-- Top row -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 pb-12 border-b border-surface-800/50">

      <!-- Brand column -->
      <div class="md:col-span-5">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-7 h-7 flex-shrink-0">
            <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
              <path d="M16 2C16 2 4 10 4 19C4 25.627 9.373 31 16 31C22.627 31 28 25.627 28 19C28 10 16 2 16 2Z" fill="oklch(0.61 0.12 60 / 0.85)"/>
              <path d="M16 6C16 6 8 13 8 20C8 24.418 11.582 28 16 28V6Z" fill="oklch(0.50 0.07 162 / 0.70)"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-lg font-medium text-white leading-none">PDX Home Revival</p>
            <p class="text-xs font-body font-light text-surface-400 tracking-[0.14em] uppercase mt-0.5">Custom Decks &amp; Patio Covers</p>
          </div>
        </div>
        <p class="font-body font-light text-sm text-surface-400 leading-relaxed max-w-xs mb-6">
          Building premium custom decks and patio covers for Portland metro homeowners since 2001. Architecturally integrated, weather-ready, crafted to last.
        </p>
        <div class="space-y-2">
          <a href="tel:5035550100" class="flex items-center gap-2 text-sm font-body text-surface-300 hover:text-accent-400 transition-colors">
            <svg class="h-4 w-4 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            (503) 555-0100
          </a>
          <a href="mailto:hello@pdxhomerevival.com" class="flex items-center gap-2 text-sm font-body text-surface-300 hover:text-accent-400 transition-colors">
            <svg class="h-4 w-4 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            hello@pdxhomerevival.com
          </a>
        </div>
      </div>

      <!-- Service areas -->
      <div class="md:col-span-3">
        <p class="text-xs font-body font-semibold tracking-[0.18em] uppercase text-surface-500 mb-5">Service Areas</p>
        <ul class="space-y-2.5">
          <li class="text-sm font-body font-light text-surface-400">Lake Oswego</li>
          <li class="text-sm font-body font-light text-surface-400">West Linn</li>
          <li class="text-sm font-body font-light text-surface-400">NW Portland</li>
          <li class="text-sm font-body font-light text-surface-400">SW Hills &amp; Tualatin Hills</li>
          <li class="text-sm font-body font-light text-surface-400">Beaverton &amp; Hillsboro</li>
          <li class="text-sm font-body font-light text-surface-400">Happy Valley &amp; Clackamas</li>
        </ul>
      </div>

      <!-- Services + Quick links -->
      <div class="md:col-span-4">
        <p class="text-xs font-body font-semibold tracking-[0.18em] uppercase text-surface-500 mb-5">What We Build</p>
        <ul class="space-y-2.5 mb-8">
          <li class="text-sm font-body font-light text-surface-400">Custom Cedar Decks</li>
          <li class="text-sm font-body font-light text-surface-400">Composite Decks (AZEK, TimberTech, Trex)</li>
          <li class="text-sm font-body font-light text-surface-400">Patio Covers &amp; Pergolas</li>
          <li class="text-sm font-body font-light text-surface-400">Louvered Roof Systems</li>
          <li class="text-sm font-body font-light text-surface-400">Multi-Level Deck Systems</li>
          <li class="text-sm font-body font-light text-surface-400">Outdoor Kitchens &amp; Lighting</li>
        </ul>
        <a
          href="#consultation"
          class="inline-flex items-center gap-2 px-6 py-3 bg-accent-500 text-white font-body font-semibold text-sm hover:bg-accent-600 transition-colors duration-150"
        >
          Free Consultation
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 pt-8">
      <p class="text-xs font-body text-surface-600">&copy; {year} PDX Home Revival, LLC. All rights reserved. · Oregon CCB Licensed &amp; Insured</p>
      <div class="flex items-center gap-6">
        <a href="/blog" class="text-xs font-body text-surface-600 hover:text-surface-400 transition-colors">Blog</a>
        <a href="#consultation" class="text-xs font-body text-surface-600 hover:text-surface-400 transition-colors">Privacy Policy</a>
        <a href="#consultation" class="text-xs font-body text-surface-600 hover:text-surface-400 transition-colors">Terms</a>
      </div>
    </div>

  </div>
</footer>
